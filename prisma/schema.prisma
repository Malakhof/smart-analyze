generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// === AUTH / MULTI-TENANT ===

model Tenant {
  id         String   @id @default(cuid())
  name       String
  plan       Plan     @default(DEMO)
  dealsUsed  Int      @default(0)
  dealsLimit Int      @default(50)
  createdAt  DateTime @default(now())

  users      User[]
  crmConfigs CrmConfig[]
  funnels    Funnel[]
  managers   Manager[]
  deals      Deal[]
  tasks      Task[]
  patterns   Pattern[]
  insights   Insight[]

  // QC relations
  scripts         Script[]
  callRecords     CallRecord[]
  messages        Message[]
  telegramConfig  TelegramConfig?

  // Pre-aggregated CRM stats (e.g. GetCourse /pl/sales/dealstat/chartdata)
  dealStatSnapshots DealStatSnapshot[]
}

enum Plan {
  DEMO
  BASIC
  STANDARD
  PRO
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      UserRole @default(VIEWER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  accounts Account[]
  sessions Session[]
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// === CRM ===

model CrmConfig {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  provider   CrmProvider
  webhookUrl String?
  apiKey     String?
  subdomain  String?
  isActive   Boolean     @default(false)
  lastSyncAt DateTime?
  createdAt  DateTime    @default(now())
  gcEmail    String?   // GetCourse login email
  gcPassword String?   // GetCourse login password (encrypted)
  gcCookie   String?   // PHPSESSID cookie (auto-refreshed)
  gcCookieAt DateTime? // When cookie was last refreshed

  // OAuth (amoCRM external integration)
  clientId     String?   // OAuth client_id
  clientSecret String?   // OAuth client_secret (encrypted)
  refreshToken String?   // OAuth refresh_token (encrypted)
  tokenExpiresAt DateTime? // When access_token expires
  redirectUri  String?   // OAuth redirect_uri registered with the integration
}

enum CrmProvider {
  BITRIX24
  AMOCRM
  GETCOURSE
}

// === SALES DATA ===

model Funnel {
  id       String        @id @default(cuid())
  tenantId String
  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  name     String
  crmId    String?
  stages   FunnelStage[]
  deals    Deal[]
}

model FunnelStage {
  id       String             @id @default(cuid())
  funnelId String
  funnel   Funnel             @relation(fields: [funnelId], references: [id])
  name     String
  // Display order in kanban. GC convention: 1..N for active stages,
  // 9999 for terminal "Won/Завершен", 10000 for terminal "Lost/Отменен".
  order    Int
  crmId    String?
  // Terminal kind derived from CRM marker (e.g. GC `system` field):
  //   null = active stage
  //   "WON"  = успешный финал (Завершен)
  //   "LOST" = отменённый финал (Отменен)
  terminalKind String?
  deals    DealStageHistory[]
}

model Manager {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  crmId     String?
  createdAt DateTime      @default(now())
  deals     Deal[]
  callRecords CallRecord[]
  messages    Message[]
  tasks       Task[]

  totalDeals      Int?
  successDeals    Int?
  conversionRate  Float?
  avgDealValue    Float?
  avgDealTime     Float?
  talkRatio       Float?
  avgResponseTime Float?
  status          ManagerStatus?
}

enum ManagerStatus {
  EXCELLENT
  WATCH
  CRITICAL
}

model Deal {
  id           String             @id @default(cuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  managerId    String?
  manager      Manager?           @relation(fields: [managerId], references: [id])
  funnelId     String?
  funnel       Funnel?            @relation(fields: [funnelId], references: [id])

  crmId        String?
  title        String
  amount       Float?
  status       DealStatus
  duration     Float?
  currentStageCrmId String?
  /// External user id of the client (GC user_id from data-user-id; amoCRM contact id)
  /// Used to link orphan conversation messages to deals.
  clientCrmId  String?

  createdAt    DateTime           @default(now())
  closedAt     DateTime?

  isAnalyzed   Boolean            @default(false)
  analysisType DealAnalysisType?

  messages     Message[]
  stageHistory DealStageHistory[]
  analysis     DealAnalysis?
  dealPatterns DealPattern[]
  callRecords  CallRecord[]
  tasks        Task[]
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum DealAnalysisType {
  TEXT
  AUDIO
  MIXED
}

model Message {
  id          String        @id @default(cuid())
  // Optional FK to Deal — GC conversation messages may not be tied to a sale
  dealId      String?
  deal        Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // Optional tenant + client/manager linkage for conversations w/o deal
  tenantId    String?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id])
  managerId   String?
  manager     Manager?      @relation(fields: [managerId], references: [id])

  // GC conversation reference (ResponseId / convId from "Обращения")
  crmId       String?
  threadId    String?       // GC respId — multiple messages share the same thread
  /// External client user id (GC) — used to backfill dealId via Deal.clientCrmId match
  clientCrmId String?
  channel     String?       // "telegram", "whatsapp", "vk", "сайт", etc

  sender    MessageSender
  content   String
  timestamp DateTime
  isAudio   Boolean       @default(false)
  audioUrl  String?
  duration  Int?
}

enum MessageSender {
  MANAGER
  CLIENT
  SYSTEM
}

model DealStageHistory {
  id        String      @id @default(cuid())
  dealId    String
  deal      Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stageId   String
  stage     FunnelStage @relation(fields: [stageId], references: [id])
  enteredAt DateTime
  leftAt    DateTime?
  duration  Float?
}

// === AI ANALYSIS ===

model DealAnalysis {
  id              String   @id @default(cuid())
  dealId          String   @unique
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  summary         String
  successFactors  String?
  failureFactors  String?
  keyQuotes       Json     // [{text, context, isPositive, dealCrmId}]
  recommendations String?
  talkRatio       Float?
  avgResponseTime Float?

  createdAt       DateTime @default(now())
}

model Pattern {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])

  type         PatternType
  title        String
  description  String

  strength     Float
  impact       Float
  reliability  Float
  coverage     Float

  dealCount    Int
  managerCount Int

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  dealPatterns DealPattern[]
}

enum PatternType {
  SUCCESS
  FAILURE
}

model DealPattern {
  id        String  @id @default(cuid())
  dealId    String
  deal      Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  patternId String
  pattern   Pattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
}

model Insight {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  type      InsightType
  title     String
  content   String

  // Rich content for accordion display
  detailedDescription String?
  dealIds             Json? // array of deal IDs where this insight appears
  managerIds          Json? // array of manager IDs
  quotes              Json? // [{text, dealCrmId}]

  createdAt DateTime @default(now())
}

enum InsightType {
  SUCCESS_INSIGHT
  FAILURE_INSIGHT
}

// === QUALITY CONTROL ===

model Script {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  category  String?  // "incoming", "outgoing", "upsell"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  items     ScriptItem[]
  callScores CallScore[]
}

model ScriptItem {
  id         String  @id @default(cuid())
  scriptId   String
  script     Script  @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  text       String
  weight     Float   @default(1.0)
  isCritical Boolean @default(false)
  order      Int
  scoreItems CallScoreItem[]
}

model CallRecord {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  managerId   String?
  manager     Manager?      @relation(fields: [managerId], references: [id])
  dealId      String?
  deal        Deal?         @relation(fields: [dealId], references: [id])
  crmId       String?
  clientName  String?
  clientPhone String?
  direction   CallDirection
  type        CommunicationType @default(CALL)
  category    String?
  audioUrl    String?
  transcript  String?
  duration    Int?
  createdAt   DateTime      @default(now())
  score       CallScore?
  tags        CallTag[]
}

enum CallDirection {
  INCOMING
  OUTGOING
}

enum CommunicationType {
  CALL
  CHAT
}

model CallScore {
  id           String          @id @default(cuid())
  callRecordId String          @unique
  callRecord   CallRecord      @relation(fields: [callRecordId], references: [id], onDelete: Cascade)
  scriptId     String
  script       Script          @relation(fields: [scriptId], references: [id])
  totalScore   Float
  items        CallScoreItem[]
  createdAt    DateTime        @default(now())
}

model CallScoreItem {
  id           String     @id @default(cuid())
  callScoreId  String
  callScore    CallScore  @relation(fields: [callScoreId], references: [id], onDelete: Cascade)
  scriptItemId String
  scriptItem   ScriptItem @relation(fields: [scriptItemId], references: [id])
  isDone       Boolean
  aiComment    String?
}

model CallTag {
  id           String     @id @default(cuid())
  callRecordId String
  callRecord   CallRecord @relation(fields: [callRecordId], references: [id], onDelete: Cascade)
  tag          String
}

model TelegramConfig {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  tenant          Tenant  @relation(fields: [tenantId], references: [id])
  botToken        String
  chatId          String
  isActive        Boolean @default(true)
  alertOnCritical Boolean @default(true)
  createdAt       DateTime @default(now())
}

enum TaskType {
  CALL
  MEETING
  LETTER
  OTHER
}

model Task {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  dealId        String?
  deal          Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  managerId     String?
  manager       Manager?  @relation(fields: [managerId], references: [id])

  crmId         String?   // amoCRM task id
  type          TaskType
  text          String
  createdAt     DateTime
  dueAt         DateTime?
  completedAt   DateTime?
  isCompleted   Boolean   @default(false)

  @@index([tenantId, managerId])
  @@index([tenantId, dealId])
}

// === PRE-AGGREGATED CRM STATS ===

// Snapshot of ready-made aggregations from CRM stat endpoints
// (e.g. GetCourse /pl/sales/dealstat/chartdata — totals + monthly chart).
// Stored as snapshots to avoid recomputing from raw deals + to support
// time-series trending (compare last week's snapshot vs this week's).
model DealStatSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  // Source identifier — e.g. "getcourse:dealstat", "amocrm:pipeline-stat"
  source      String
  // Optional scope identifiers — manager filter, product filter, period.
  // Empty/null = all-time, all managers, all products.
  scopeJson   Json?

  // Totals block
  ordersCreatedCount   Int?
  ordersCreatedAmount  Float?
  ordersPaidCount      Int?
  ordersPaidAmount     Float?
  buyersCount          Int?
  prepaymentsCount     Int?
  prepaymentsAmount    Float?
  taxAmount            Float?
  commissionAmount     Float?
  earnedAmount         Float?

  // Monthly chart series — array of [{name, points: [{month, value}]}]
  seriesJson  Json?

  // Raw payload for debugging / re-parsing
  rawJson     Json?

  capturedAt  DateTime @default(now())

  @@index([tenantId, source, capturedAt])
}
